# ─── Backend API URL ───────────────────────────────────────────────────────────
# In development: your local backend
# In production: your Railway backend URL e.g. https://dahlia-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Cloudinary ────────────────────────────────────────────────────────────────
# Your Cloudinary cloud name (find in Cloudinary dashboard)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Upload preset — create an UNSIGNED preset in Cloudinary settings named "dahlia"
# Settings → Upload → Upload presets → Add preset → Mode: Unsigned
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=dahlia
