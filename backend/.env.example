# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── Admin Authentication ──────────────────────────────────────────────────────
ADMIN_KEY="your-secret-admin-key"
ADMIN_EMAIL="admin@example.com"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Frontend URL (used for Stripe redirect URLs) ─────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Dahlia Baasher <noreply@dahliabaasher.com>"

# ─── Shipping (EasyPost) ──────────────────────────────────────────────────────
EASYPOST_API_KEY="EZTKtest_..."
SHIP_FROM_NAME="Dahlia Baasher"
SHIP_FROM_STREET="123 Studio Street"
SHIP_FROM_CITY="Cairo"
SHIP_FROM_STATE="CA"
SHIP_FROM_ZIP="00000"
SHIP_FROM_COUNTRY="EG"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
