# ─── Database (Railway provides this automatically) ───────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dahlia"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."   # From: Stripe Dashboard → Webhooks

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY="re_..."
EMAIL_FROM="orders@dahliabaasher.com"   # Must match your verified Resend domain

# ─── EasyPost (shipping labels) ───────────────────────────────────────────────
# Get from: https://www.easypost.com/account/api-keys
EASYPOST_API_KEY="EZTKxxxx..."

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="https://your-frontend.railway.app"
NODE_ENV="production"

# ─── Shipping from address (Dahlia's studio) ─────────────────────────────────
SHIP_FROM_NAME="Dahlia Baasher"
SHIP_FROM_STREET="123 Studio Street"
SHIP_FROM_CITY="Cairo"
SHIP_FROM_STATE="CA"
SHIP_FROM_ZIP="12345"
