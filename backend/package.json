    "resend": "^3.2.0",
    "stripe": "^14.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
