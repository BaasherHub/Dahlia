generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Painting {
  id          String   @id @default(cuid())
  title       String
  description String
  
  // Original painting
  originalPrice       Float?
  originalAvailable   Boolean @default(true)
  
  // Print version
  printPrice          Float?
  printAvailable      Boolean @default(false)
  
  images      String[]
  dimensions  String
  medium      String
  year        Int?
  sold        Boolean  @default(false)
  featured    Boolean  @default(false)
  heroImage   Boolean  @default(false)
  
  // Category: "original" | "print" | "both"
  category    String   @default("original")
  
  // Collection
  collection  Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Collection {
  id          String     @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  order       Int        @default(0)
  paintings   Painting[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Order {
  id               String      @id @default(cuid())
  stripePaymentId  String      @unique
  stripeSessionId  String      @unique
  status           OrderStatus @default(PENDING)
  customerEmail    String
  customerName     String
  shipName         String
  shipStreet       String
  shipCity         String
  shipState        String
  shipZip          String
  shipCountry      String
  shipPhone        String?
  trackingCode     String?
  labelUrl         String?
  carrier          String?
  total            Float
  items            OrderItem[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OrderItem {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  painting   Painting @relation(fields: [paintingId], references: [id])
  paintingId String
  price      Float
  version    String   @default("original") // "original" | "print"
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model SiteSettings {
  id    String @id @default("singleton")
  
  // About page content
  aboutHeroSubtitle   String @default("Contemporary artist creating refined works on premium linen canvas")
  aboutBio1           String @default("I am a contemporary artist specializing in oil paintings on premium linen canvas. My work is defined by deliberate palette knife technique and expressive brushwork, creating pieces that resonate with collectors and designers worldwide.")
  aboutBio2           String @default("Each painting begins with careful consideration of color, composition, and emotional resonance. I work exclusively with the finest materials to ensure longevity and visual impact that endures through time.")
  aboutBio3           String @default("My practice combines technical precision with spontaneous creativity, resulting in works that are both carefully considered and intuitively executed.")
  aboutStatement1     String @default("My practice is rooted in a deep engagement with color, form, and the physical materiality of paint. I create work that exists in conversation with contemporary art practice while maintaining a reverence for the traditions of painting.")
  aboutStatement2     String @default("Through careful observation and intuitive response, I build paintings that invite contemplation and emotional engagement. Each piece is an attempt to capture a moment of synthesis between intention and spontaneity, between control and surrender.")
  aboutStatement3     String @default("I am committed to creating work of lasting value—both visually and materially. My practice is defined by a pursuit of excellence and a dedication to the craft of painting.")
  
  // Testimonials (stored as JSON array)
  testimonials        String @default("[]")

  // Homepage content
  heroTitle           String @default("Dahlia Baasher")
  heroSubtitle        String @default("Contemporary Oil Paintings")
  heroDescription     String @default("Refined works on premium linen canvas, defined by deliberate palette knife technique and expressive brushwork.")
  featuredWorksTitle  String @default("Featured Works")
  featuredWorksSubtitle String @default("Original Paintings")
  printsTitle         String @default("Limited Edition Prints")
  printsSubtitle      String @default("High-Quality Reproductions")
  ctaTitle            String @default("Ready to Commission?")
  ctaDescription      String @default("I work with collectors and designers worldwide to create bespoke artwork tailored to your vision and space.")
  newsletterTitle     String @default("Stay Updated")
  newsletterSubtitle  String @default("Subscribe to receive updates about new artworks, exhibitions, and commission opportunities.")

  // Footer
  footerTagline       String @default("Contemporary Art · Toronto, Canada")
  socialLinks         String @default("[]")

  // Commissions page
  commissionsSubtitle   String @default("I work with collectors and designers worldwide to create bespoke artwork tailored to your vision and space.")
  commissionSteps       String @default("[]")
  commissionFaqs        String @default("[]")
  commissionFormHelpText String @default("I typically respond within 48 hours. Looking forward to collaborating with you!")

  // About page practice cards (JSON array)
  practiceCards       String @default("[]")

  // About page: exhibitions & publications (JSON arrays)
  exhibitions         String @default("[]")
  publications        String @default("[]")
  aboutArtistImage    String?

  // Gallery page
  galleryLabel        String @default("Portfolio")
  galleryTitle        String @default("Artworks")
  gallerySubtitle     String @default("Explore original paintings and limited edition prints")

  // Navigation
  navLogoSubtext      String @default("Studio")

  // Portfolio page
  portfolioTitle      String @default("Portfolio")
  portfolioSubtitle   String @default("A curated selection of original works")
  portfolioStatement  String @default("Each painting is a meditation on color, form, and the expressive potential of oil on linen. These selected works represent the breadth of my practice — from intimate studies to large-scale statements.")

  updatedAt           DateTime @updatedAt
}

model CommissionInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  vision    String
  size      String
  budget    String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
